#!/bin/bash
cd "$HOME/dotfiles" || exit

# Identity Check (Keep this to ensure signatures work)
EXPECTED_KEY="$HOME/.ssh/id_ed25519_personal_sign.pub"
if [ "$(git config user.signingkey)" != "$EXPECTED_KEY" ]; then
    git config user.email "jeff@skiddle.id"
    git config user.signingkey "$EXPECTED_KEY"
fi

echo "🔄 Staging changes..."
git add -A

# Generate AI Commit Message (Flag removed)
echo "🤖 Generating AI commit message..."
if aicommits; then
    echo "🚀 Pushing to origin..."
    git push origin main
    notify-send "Dotfiles" "AI-Generated commit synced and signed ✅"
else
    notify-send "Dotfiles" "❌ AI Commit failed"
    exit 1
fi